{
  "manifest_version": 3,
  "name": "XT-Neros",
  "version": "2.0.0",
  "description": "Ghost Session Protocol — Cookie vault with network-level phantom injection",

  "permissions": [
    "cookies",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms"
  ],

  "host_permissions": [
    "*://*.roblox.com/*",
    "*://*.rbxcdn.com/*",
    "*://*.roblox.qq.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}